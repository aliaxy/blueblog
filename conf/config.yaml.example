name: "blueblog"
mode: "dev"          # dev | release
port: 8888
version: "v0.0.1"
start_time: "2023-07-01"
machine_id: 1

auth:
  jwt_expire: 8760   # JWT 有效期（小时）

log:
  level: "debug"
  filename: "blueblog.log"
  max_size: 200      # 单文件最大 MB
  max_age: 30        # 保留天数
  max_backups: 7     # 最多备份份数

mysql:
  host: "127.0.0.1"
  port: 3306
  user: "root"
  password: "your_password"
  dbname: "blueblog"
  max_open_conns: 200
  max_idle_conns: 50

redis:
  host: "127.0.0.1"
  port: 6379
  db: 0
  password: ""
  pool_size: 100
